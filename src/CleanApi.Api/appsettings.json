{
  "Serilog": {
    "Using": [ "Serilog.Sinks.Console", "Serilog.Sinks.File" ],
    "MinimumLevel": {
      "Default": "Information",
      "Override": {
        "Microsoft.AspNetCore": "Warning",
        "Microsoft.EntityFrameworkCore": "Warning",
        "Hangfire": "Warning"
      }
    },
    "WriteTo": [
      { "Name": "Console" },
      {
        "Name": "File",
        "Args": {
          "path": "logs/log-.txt",
          "rollingInterval": "Day",
          "retainedFileCountLimit": 7
        }
      }
    ],
    "Enrich": [ "FromLogContext" ]
  },
  "ConnectionStrings": {
    "Default": "Server=localhost,1433;Database=CleanApi;User Id=sa;Password=Your_password123;TrustServerCertificate=True",
    "Redis": "",
    "Hangfire": ""
  },
  "Jwt": {
    "Issuer": "CleanApi",
    "Audience": "CleanApiClients",
    "AccessTokenMinutes": 15,
    "RefreshTokenDays": 7
  },
  "Email": {
    "Host": "localhost",
    "Port": 1025,
    "UseSsl": false,
    "FromAddress": "no-reply@example.com",
    "FromName": "CleanApi"
  },
  "Firebase": {
    "ServiceAccountPath": ""
  },
  "Seed": {
    "SeedSampleData": true,
    "AdminEmail": "admin@example.com"
  },
  "Database": {
    "ApplyMigrationsOnStartup": false
  },
  "Hangfire": {
    "UseSqlServerStorage": false
  },
  "Cors": {
    "AllowedOrigins": []
  },
  "Sentry": {
    "Dsn": "",
    "TracesSampleRate": 0.0
  },
  "OpenTelemetry": {
    "ServiceName": "CleanApi",
    "OtlpEndpoint": ""
  },
  "AllowedHosts": "*"
}
