{
  "//": "Production overrides. Do NOT put secrets here — supply them via environment variables or a secret store.",
  "//secrets": [
    "ConnectionStrings__Default",
    "ConnectionStrings__Redis",
    "Jwt__SigningKey  (required, >= 32 chars)",
    "Email__Username / Email__Password",
    "Sentry__Dsn",
    "Firebase__ServiceAccountPath",
    "Seed__AdminPassword"
  ],
  "Serilog": {
    "MinimumLevel": {
      "Default": "Warning",
      "Override": {
        "CleanApi": "Information"
      }
    }
  },
  "Database": {
    "ApplyMigrationsOnStartup": false
  },
  "Hangfire": {
    "UseSqlServerStorage": true
  },
  "Cors": {
    "AllowedOrigins": [ "https://your-frontend.example.com" ]
  }
}
